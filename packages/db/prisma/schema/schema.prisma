generator client {
  provider     = "prisma-client"
  output       = "../generated"
  moduleFormat = "esm"
  runtime      = "bun"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String      @id @default(cuid())
  email         String
  name          String?
  emailVerified Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  isOnboarded   Boolean     @default(false)
  sessions      Session[]
  accounts      Account[]
  role          ProfileType @default(CUSTOMER)
  customer      Customer?
  theatre       Theatre?

  @@unique([email])
  @@map("user")
}

model Session {
  id        String   @id @default(cuid())
  expiresAt DateTime
  token     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  ipAddress String?
  userAgent String?
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([token])
  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  accountId             String
  providerId            String
  userId                String
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  accessToken           String?
  refreshToken          String?
  idToken               String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

enum ProfileType {
  CUSTOMER
  OWNER
  ADMIN
}

model Customer {
  id     String @id @default(cuid())
  name   String
  userId String @unique

  orders           Order[]
  ticket           Ticket[]
  seatReservations ShowSeatReservation[]
  user             User                  @relation(fields: [userId], references: [id])
}

model Theatre {
  id            String @id @default(cuid())
  userId        String @unique
  title         String
  address       String
  city          String
  country       String
  theatreMovies Show[]
  seat          Seat[]
  user          User   @relation(fields: [userId], references: [id])
}

model Movie {
  id            String      @id @default(cuid())
  title         String
  description   String
  rating        Int
  crew          Json        @default("{}")
  tags          MOVIE_TAG[]
  theatreMovies Show[]
}

model Show {
  id        String     @id @default(cuid())
  theatreId String
  movieId   String
  startTime DateTime
  endTime   DateTime
  theatre   Theatre    @relation(fields: [theatreId], references: [id])
  movie     Movie      @relation(fields: [movieId], references: [id])
  showSeats ShowSeat[]

  @@unique([theatreId, movieId, startTime])
}

model Seat {
  id                String     @id @default(cuid())
  theatreId         String
  row               String
  col               Int
  theatre           Theatre    @relation(fields: [theatreId], references: [id])
  theatreMovieSeats ShowSeat[]

  @@unique([theatreId, row, col])
}

enum SEAT_STATUS {
  AVAILABLE
  SOLD
}

model ShowSeat {
  id     String      @id @default(cuid())
  showId String
  seatId String
  status SEAT_STATUS @default(AVAILABLE)
  price  Int

  show             Show                  @relation(fields: [showId], references: [id])
  seat             Seat                  @relation(fields: [seatId], references: [id])
  seatReservations ShowSeatReservation[]
  ticket           Ticket?
  orders           Order[]

  @@unique([seatId, showId])
}

model ShowSeatReservation {
  id         String   @id @default(cuid())
  customerId String
  showSeatId String
  reservedAt DateTime
  duration   Int

  customer Customer @relation(fields: [customerId], references: [id])
  showSeat ShowSeat @relation(fields: [showSeatId], references: [id])
}

model Ticket {
  id         String   @id @default(cuid())
  showSeatId String   @unique
  createdAt  DateTime @default(now())
  customerId String

  customer Customer @relation(fields: [customerId], references: [id])
  showSeat ShowSeat @relation(fields: [showSeatId], references: [id])
}

enum ORDER_STATUS {
  SUCCESS
  PENDING
  FAILED
}

enum PAYMENT_STATUS {
  SUCCESS
  PENDING
  FAILED
}

enum CURRENCY {
  USD
  INR
}

enum PAYMENT_PROVIDER {
  STRIPE
}

model Order {
  id         String       @id @default(cuid())
  status     ORDER_STATUS
  customerId String
  showSeatId String
  createdAt  DateTime     @default(now())
  updatedAt  DateTime     @updatedAt
  payment    Payment?
  customer   Customer     @relation(fields: [customerId], references: [id])
  showSeat   ShowSeat     @relation(fields: [showSeatId], references: [id])
}

model Payment {
  id              String           @id @default(cuid())
  amount          Int
  currency        CURRENCY
  orderId         String           @unique
  paymentId       String           @unique
  paymentProvider PAYMENT_PROVIDER
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  order Order @relation(fields: [orderId], references: [id])
}

enum MOVIE_TAG {
  // Primary Genres
  ACTION
  ADVENTURE
  COMEDY
  CRIME
  DRAMA
  DOCUMENTARY
  FAMILY
  FANTASY
  HORROR
  MUSICAL
  MYSTERY
  ROMANCE
  SCIENCE_FICTION
  THRILLER
  WESTERN
  WAR

  // Subgenres
  SUPERHERO
  MARTIAL_ARTS
  SPY
  HEIST
  ROMANTIC_COMEDY
  BLACK_COMEDY
  SATIRE
  SLAPSTICK
  FILM_NOIR
  WHODUNIT
  DETECTIVE
  TRUE_CRIME
  BIOGRAPHY
  HISTORICAL
  MELODRAMA
  COMING_OF_AGE
  CYBERPUNK
  SPACE_OPERA
  DYSTOPIAN
  STEAMPUNK
  SLASHER
  PSYCHOLOGICAL
  BODY_HORROR
  ZOMBIE
  SUPERNATURAL
  NEO_WESTERN
  SPAGHETTI_WESTERN
  EMPIRE_WESTERN
}
