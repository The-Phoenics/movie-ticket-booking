{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs",
    "populate": "bun run src/populate.ts",
    "lint": "eslint ."
  },
  "dependencies": {
    "@movie-ticket-booking/auth": "workspace:*",
    "@movie-ticket-booking/cache": "workspace:*",
    "@movie-ticket-booking/db": "workspace:*",
    "@movie-ticket-booking/env": "workspace:*",
    "@movie-ticket-booking/queue": "workspace:*",
    "better-auth": "catalog:",
    "bullmq": "^5.80.0",
    "cors": "^2.8.5",
    "dotenv": "catalog:",
    "express": "^5.1.0",
    "stripe": "^22.2.2",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@movie-ticket-booking/config": "workspace:*",
    "@movie-ticket-booking/shared": "workspace:*",
    "@types/bun": "catalog:",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/stripe": "^8.0.417",
    "eslint": "^10.7.0",
    "globals": "^17.7.0",
    "tsdown": "^0.21.9",
    "typescript": "catalog:",
    "typescript-eslint": "^8.63.0"
  }
}
